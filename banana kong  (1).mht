@charset "utf-8";

body { font-family: Cairo, Quicksand, sans-serif; user-select: none; overflow: hidden; background-color: rgb(18, 3, 36); }

.arabic-text { font-family: Cairo, sans-serif; }

.title-font { font-family: "Fredoka One", Cairo, sans-serif; }

::-webkit-scrollbar { width: 6px; }

::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }

::-webkit-scrollbar-thumb { background: rgb(245, 158, 11); border-radius: 10px; }

@keyframes shake { 
  0%, 100% { transform: translate(0px, 0px); }
  10%, 30%, 50%, 70%, 90% { transform: translate(-6px, 0px); }
  20%, 40%, 60%, 80% { transform: translate(6px, 0px); }
}

.shake-ui { animation: 0.4s ease-in-out 0s 1 normal none running shake; }

@keyframes windSway { 
  0%, 100% { transform: rotate(0deg); }
  50% { transform: rotate(1.5deg); }
}

@keyframes driftLeaf { 
  0% { transform: translateY(-50px) translateX(0px) rotate(0deg); opacity: 0; }
  10% { opacity: 0.8; }
  90% { opacity: 0.8; }
  100% { transform: translateY(105vh) translateX(120px) rotate(360deg); opacity: 0; }
}

@keyframes driftPetal { 
  0% { transform: translateY(-50px) translateX(0px) rotate(0deg); opacity: 0; }
  10% { opacity: 0.9; }
  90% { opacity: 0.9; }
  100% { transform: translateY(105vh) translateX(-150px) rotate(720deg); opacity: 0; }
}

@keyframes driftSnowflake { 
  0% { transform: translateY(-50px) translateX(0px) rotate(0deg); opacity: 0; }
  10% { opacity: 0.8; }
  90% { opacity: 0.8; }
  100% { transform: translateY(105vh) translateX(60px) rotate(180deg); opacity: 0; }
}

.scenic-sway { animation: 6s ease-in-out 0s infinite normal none running windSway; transform-origin: center bottom; }
